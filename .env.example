# ============================================================
# API Keys 配置 —— 复制此文件为 .env 并填入真实密钥
# ============================================================

# VLM API（兼容 OpenAI 格式，如 Qwen-VL、GPT-4V 等）
API_KEY=your_api_key_here
MODEL_NAME=qwen-vl-max
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Serper —— web_search / image_search(text) / Google Lens（image_search reverse）
# 注册：https://serper.dev     一个 KEY 同时支持 web search、图片搜索、Google Lens reverse
# 没有时 reverse 会自动 fallback 到 VLM describe workaround
SERPER_KEY=

# Tavily —— 备用 web_search（已弃用）
TAVILY_API_KEY=

# E2B —— code_interpreter 沙箱
# 注册：https://e2b.dev        免费额度：100小时/月
E2B_API_KEY=

# Jina Reader —— visit 工具（网页抓取）
# 注册：https://jina.ai        免费额度有限
JINA_API_KEY=
